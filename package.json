{
  "name": "teacher",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "db:push": "sh -ac 'set -a && . ./.env && set +a && pnpm dlx supabase db push --db-url \"$DATABASE_URL\"'",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.5",
    "typescript": "^5.8.3"
  }
}
